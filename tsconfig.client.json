{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "outDir": "./build/client",
        "rootDir": "./src/client/src",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "target": "ES2020",
        "jsx": "react-jsx",
        "baseUrl": ".",
        "paths": {
            "@/*": ["src/client/src/*"],
            "@/app": ["src/client/src/app"],
            "@/features/*": ["src/client/src/features/*"],
            "@/shared/*": ["src/client/src/shared/*"]
        }
    },
    "include": ["src/client/src/**/*"],
    "exclude": ["src/server/**/*", "src/**/*.test.ts"]
}
